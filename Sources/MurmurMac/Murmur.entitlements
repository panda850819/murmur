<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Sprint 5 (2026-05-16): App Sandbox removed. macOS ships as a signed DMG,
  not via the Mac App Store (per BRIEF), so sandbox is optional — and a
  sandboxed app cannot post synthetic ⌘V into another app (the v0.1 core
  dictation loop). Mic is gated by NSMicrophoneUsageDescription (Info.plist);
  the global hotkey + auto-paste are gated by Accessibility (TCC, runtime),
  neither of which is an entitlement. Empty by design.
-->
<plist version="1.0">
<dict>
</dict>
</plist>
